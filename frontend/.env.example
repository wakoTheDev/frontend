# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: override OAuth redirect URL (must match Supabase Auth → Redirect URLs exactly)
# VITE_AUTH_REDIRECT_URL=http://localhost:5173

# Backend API URL (optional - in dev, requests proxy to http://localhost:3001)
# In production (e.g., Vercel), set this to your backend URL
# VITE_API_BASE_URL=https://your-backend-url/api

