# Production environment variables for frontend

# Supabase production URLs (same as dev, but can use different project if desired)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Production backend API URL (change to your deployed backend domain)
VITE_API_BASE_URL=https://your-backend-domain.com/api

# Optional: OAuth redirect URL for production
# VITE_AUTH_REDIRECT_URL=https://your-frontend-domain.com
