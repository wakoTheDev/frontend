PORT=3001
# Backend terminal logging: error | warn | info | debug
LOG_LEVEL=info

# Optional: Crop Model URL (Railway predict endpoint)
# When set, image analysis requests are forwarded to this endpoint before falling back to local analysis
# CROP_MODEL_URL=https://your-railway-app.up.railway.app/predict

# OpenRouter API (AI recommendations / insights)
OPEN_ROUTER_API_KEY=sk-or-v1-your-key-here
OPENAI_MODEL=gpt-4o

# Supabase (required for account deletion API — use service role key, never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional: if you only set frontend-style names in .env
# VITE_SUPABASE_URL=
# VITE_SUPABASE_SERVICE_ROLE_KEY=

# Frontend URL (for account deletion email links, redirects)
FRONTEND_URL=http://localhost:5173

# Email (account deletion confirmation)
#
# Option A — Gmail: use an App Password (NOT your normal password).
#   1) Google Account → Security → 2-Step Verification ON
#   2) App passwords → generate → paste the 16 chars as SMTP_PASSWORD
#   3) SMTP_USER = full gmail address. Error 535 = wrong password or app password revoked.
#
# Option B — SendGrid only if the key starts with SG. (real SendGrid API key).
# If SMTP_USER/SMTP_PASSWORD are set, SMTP is used first (Brevo, Gmail, etc.).
# SENDGRID_API_KEY=SG.xxxxx
#
# Option C — Brevo: https://app.brevo.com/settings/keys/smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=xxxx@smtp-brevo.com
# SMTP_PASSWORD=<SMTP key from "SMTP" section — NOT the API key from "API keys" (xkeysib API keys do not work for SMTP).>
# EMAIL_FROM / FEEDBACK_REPLY_FROM must be verified under Brevo → Settings → Senders.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=16-char-app-password

EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=AI-Powered CropCare

# Public support / developer contact (mailto in app; default inbox for feedback if FEEDBACK_EMAIL unset)
SUPPORT_EMAIL=aipoweredcropcare@zohomail.com
# From address for admin feedback replies (use your Zoho mailbox; must match SMTP auth for Zoho)
FEEDBACK_REPLY_FROM=aipoweredcropcare@zohomail.com
# Where new user feedback notifications are sent (optional; defaults to SUPPORT_EMAIL)
# FEEDBACK_EMAIL=aipoweredcropcare@zohomail.com
